          style={{
            width: "100%",
            padding: "10px 14px",
            background: "rgba(255,255,255,.05)",
            border: "1px solid rgba(91,155,213,.25)",
            borderRadius: "8px",
            color: "#ddeeff",
            fontFamily: "monospace",
            fontSize: "12px",
