          style={tagStyle(!activeCategory, "#5b9bd5")}
        >
          All ({TERMS.length})
        </button>
        {CATEGORIES.map((cat) => (
          <button
            key={cat}
            onClick={() =>
              setActiveCategory(activeCategory === cat ? null : cat)
            }
            style={tagStyle(activeCategory === cat, CATEGORY_COLORS[cat])}
          >
            {cat} ({TERMS.filter((t) => t.category === cat).length})
          </button>
        ))}
      </div>

      {/* A-Z index */}
      <div
        style={{
          display: "flex",
          gap: "4px",
          marginBottom: "28px",
          flexWrap: "wrap",
        }}
      >
        {LETTERS.map((letter) => {
          const available = availableLetters.has(letter);
          const active = activeLetter === letter;
          return (
            <button
              key={letter}
              onClick={() => available && scrollToLetter(letter)}
              style={{
                width: "24px",
                height: "24px",
                fontFamily: "monospace",
                fontSize: "10px",
                borderRadius: "4px",
                cursor: available ? "pointer" : "default",
                border: active
                  ? "1px solid #5b9bd5"
                  : "1px solid rgba(255,255,255,.06)",
                background: active
                  ? "rgba(91,155,213,.2)"
                  : available
                    ? "rgba(255,255,255,.04)"
                    : "none",
                color: active
                  ? "#5b9bd5"
                  : available
                    ? "rgba(180,210,240,.7)"
                    : "rgba(180,210,240,.15)",
                padding: 0,
              }}
            >
              {letter}
            </button>
          );
        })}
        {activeLetter && (
          <button
            onClick={() => setActiveLetter(null)}
            style={{
              padding: "0 10px",
              height: "24px",
              fontFamily: "monospace",
              fontSize: "9px",
              borderRadius: "4px",
              cursor: "pointer",
              border: "1px solid rgba(255,100,100,.3)",
              background: "rgba(255,100,100,.08)",
              color: "rgba(255,130,130,.8)",
            }}
          >
            ✕ clear
          </button>
        )}
      </div>

      {/* Results count */}
      <div
        style={{
          fontSize: "10px",
          color: "rgba(180,210,240,.35)",
          marginBottom: "16px",
        }}
      >
        {filtered.length} term{filtered.length !== 1 ? "s" : ""}
        {search || activeCategory || activeLetter
          ? " matching filters"
          : " total"}
      </div>

      {/* Terms grid */}
      {filtered.length === 0 ? (
        <div
          style={{
            textAlign: "center",
            padding: "40px",
            color: "rgba(180,210,240,.3)",
            fontSize: "12px",
          }}
        >
          No terms found matching your search.
        </div>
      ) : (
        <div
          style={{
            display: "grid",
            gridTemplateColumns: "repeat(auto-fill, minmax(340px, 1fr))",
            gap: "10px",
          }}
        >
          {filtered.map((t) => {
            const col = CATEGORY_COLORS[t.category];
            return (
              <div
                key={t.term}
                style={{
                  background: "rgba(255,255,255,.025)",
                  border: "1px solid rgba(255,255,255,.07)",
                  borderRadius: "8px",
                  padding: "14px 16px",
                  transition: "border-color .2s",
                }}
                onMouseEnter={(e) =>
                  (e.currentTarget.style.borderColor = `${col}44`)
                }
                onMouseLeave={(e) =>
                  (e.currentTarget.style.borderColor = "rgba(255,255,255,.07)")
                }
              >
                <div
                  style={{
                    display: "flex",
                    justifyContent: "space-between",
                    alignItems: "flex-start",
                    marginBottom: "6px",
                  }}
                >
                  <span
                    style={{
                      fontSize: "13px",
                      fontWeight: 700,
                      color: "#ddeeff",
                    }}
                  >
                    {t.term}
                  </span>
                  <span
                    style={{
                      fontSize: "8px",
                      padding: "2px 7px",
                      borderRadius: "3px",
                      background: `${col}22`,
                      color: col,
                      letterSpacing: ".08em",
                      flexShrink: 0,
                      marginLeft: "8px",
                    }}
                  >
                    {t.category.toUpperCase()}
                  </span>
                </div>
                <p
                  style={{
                    fontSize: "11px",
                    color: "rgba(180,210,240,.7)",
                    lineHeight: 1.7,
                    margin: "0 0 8px",
                  }}
                >
                  {t.definition}
                </p>
                <div
                  style={{
                    fontSize: "10px",
                    color: col,
                    lineHeight: 1.6,
                    paddingTop: "8px",
                    borderTop: `1px solid ${col}22`,
                  }}
                >
                  💡 {t.matters}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}
